# ローカル開発用（frontend/.env.local にコピー）
# Backend を docker compose / uvicorn で起動している場合
BACKEND_URL=http://localhost:8000

# Railway 本番（Frontend サービスの Variables に設定）
# BACKEND_URL=https://<your-backend-service>.up.railway.app
# または同一プロジェクト内プライベートネットワーク:
# BACKEND_RAILWAY_SERVICE=<backend-service-name>
# BACKEND_PORT=8080
