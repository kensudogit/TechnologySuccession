OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
PROMPT_VERSION=v1

# RAG 検索パラメータ
RETRIEVAL_TOP_K=12
RRF_TOP_K=8
RERANK_TOP_K=5
CHUNK_MAX_CHARS=600
CHUNK_OVERLAP=80

# Railway: PostgreSQL プラグインが自動設定
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/technology_succession

# Railway: JWT_SECRET を設定すると API 認証が有効化される
JWT_SECRET=
JWT_EXPIRE_HOURS=24
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
DATA_DIR=./data
DEBUG=false
